<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.3.0 Chrome/140.0.7339.249 Electron/38.7.2 Safari/537.36" version="29.3.0">
  <diagram name="Page-1" id="ISuFWbc_N_UfGSev70V3">
    <mxGraphModel dx="2084" dy="1252" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="V2mJWq3PVGsmjri88hrf-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;AIM: Design an E-commerce system with following requirements:&lt;/font&gt;&lt;/b&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;1. User login service&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;2. Product catalog service&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;3. Cart service&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;4. Search Service&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;5. Order status service&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;6. Check out service&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Optimize the product searching and Inventory Stock Management in real-time&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="610" x="675.6" y="240" as="geometry" />
        </mxCell>
        <mxCell id="V2mJWq3PVGsmjri88hrf-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;1. FUNCTIONAL REQUIREMENTS&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="40" width="340" x="116" y="530" as="geometry" />
        </mxCell>
        <mxCell id="V2mJWq3PVGsmjri88hrf-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;a. User should be able to login and sign up&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;b. User should be able to search products efficiently&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;c. User should be able to add items in the cart&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;d. User should be able to make orders following by payment transactions&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="600" x="151" y="565" as="geometry" />
        </mxCell>
        <mxCell id="V2mJWq3PVGsmjri88hrf-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;2. NON-FUNCTIONAL REQUIREMENTS&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="40" width="390" x="116" y="695" as="geometry" />
        </mxCell>
        <mxCell id="V2mJWq3PVGsmjri88hrf-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;a. System should be able to handle Millions (1-1.5M) of daily active users.&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;b. CAP Theorem:&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&amp;nbsp; &amp;nbsp; Availability &amp;gt;&amp;gt;&amp;gt;&amp;gt;&amp;gt; Consistency&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;c. System should be able to handle concurrency issues&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;d. Order payment latency ~500ms. (Network+PaymentGateway Latency+ Application + DataBase Latency.)&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="880" x="151" y="730" as="geometry" />
        </mxCell>
        <mxCell id="V2mJWq3PVGsmjri88hrf-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;3. API Desgn&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="40" width="150" x="116" y="865" as="geometry" />
        </mxCell>
